# ==================================

uploads/

# ==================================
# Node.js
# ==================================

node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ==================================
# React / Vite
# ==================================

dist/
build/

# ==================================
# VS Code
# ==================================

.vscode/

# ==================================
# IntelliJ
# ==================================

.idea/

# ==================================
